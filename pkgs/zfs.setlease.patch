+dnl # linux/fs.h to linux/filelock.h
+dnl #
+AC_DEFUN([ZFS_AC_KERNEL_SRC_FILELOCK_HEADER], [
+	ZFS_LINUX_TEST_SRC([filelock_header], [
+		#include <linux/fs.h>
